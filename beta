-- State
local selectedEntry = nil
local dropOpen = false

local function closeDropdown()
	dropOpen = false
	dropScroll.Visible = false
	dropScroll.Size = UDim2.new(0.9, 0, 0, 0)
	rarityBox.Position = UDim2.new(0.05, 0, 0, 122)
	priceBox.Position = UDim2.new(0.05, 0, 0, 156)
	applyBtn.Position = UDim2.new(0.05, 0, 0, 188)
	main.Size = UDim2.new(0, 220, 0, 220)
end

local function openDropdown()
	for _, c in ipairs(dropScroll:GetChildren()) do
		if c:IsA("TextButton") then c:Destroy() end
	end

	local brainrots = getBrainrots()
	local rowH = 26
	local maxVisible = math.min(#brainrots, 4)
	local dropHeight = maxVisible * rowH

	for _, entry in ipairs(brainrots) do
		local btn = Instance.new("TextButton", dropScroll)
		btn.Size = UDim2.new(1, 0, 0, rowH)
		btn.BackgroundTransparency = 1
		btn.Text = entry.name
		btn.Font = Enum.Font.Gotham
		btn.TextSize = 11
		btn.TextColor3 = Color3.fromRGB(220, 220, 220)

		btn.MouseButton1Click:Connect(function()
			selectedEntry = entry
			dropBtn.Text = entry.name .. " ▼"
			closeDropdown()
		end)
	end

	dropScroll.CanvasSize = UDim2.new(0, 0, 0, #brainrots * rowH)
	dropScroll.Size = UDim2.new(0.9, 0, 0, dropHeight)
	dropScroll.Visible = true

	local offset = 64 + dropHeight + 6
	rarityBox.Position = UDim2.new(0.05, 0, 0, offset)
	priceBox.Position = UDim2.new(0.05, 0, 0, offset + 34)
	applyBtn.Position = UDim2.new(0.05, 0, 0, offset + 68)
	main.Size = UDim2.new(0, 220, 0, offset + 100)
end

-- Toggle dropdown
dropBtn.MouseButton1Click:Connect(function()
	dropOpen = not dropOpen
	if dropOpen then
		openDropdown()
	else
		closeDropdown()
	end
end)

-- Apply
applyBtn.MouseButton1Click:Connect(function()
	if not selectedEntry then
		applyBtn.Text = "Select one!"
		task.wait(1)
		applyBtn.Text = "Apply"
		return
	end

	if rarityBox.Text ~= "" and selectedEntry.rarityLabel then
		selectedEntry.rarityLabel.Text = rarityBox.Text
		local color = rarityColors[rarityBox.Text]
		if color then
			selectedEntry.rarityLabel.TextColor3 = color
		end
	end

	if priceBox.Text ~= "" and selectedEntry.priceLabel then
		selectedEntry.priceLabel.Text = priceBox.Text
	end

	applyBtn.Text = "✅ Done!"
	applyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
	task.wait(1.5)
	applyBtn.Text = "Apply"
	applyBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
end)

-- J to toggle
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.J then
		main.Visible = not main.Visible
	end
end)
