-- Get all brainrots via AnimalOverhead
local function getBrainrots()
	local list = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj.Name == "AnimalOverhead" then
			local nameLabel = obj:FindFirstChild("DisplayName")
			local priceLabel = obj:FindFirstChild("Price")
			local rarityLabel = obj:FindFirstChild("Rarity")

			if nameLabel and nameLabel.Text ~= "" then
				table.insert(list, {
					name = nameLabel.Text,
					overhead = obj,
					nameLabel = nameLabel,
					priceLabel = priceLabel,
					rarityLabel = rarityLabel,
				})
			end
		end
	end
	return list
end

